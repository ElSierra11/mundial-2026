# ─── CONFIGURACIÓN DE NOTIFICACIONES POR CORREO (SMTP) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=tu_correo@gmail.com
# Para Gmail, usa una "Contraseña de aplicación" generada en tu cuenta de Google, NO tu contraseña normal
SMTP_PASSWORD=tu_contrasena_de_aplicacion
SMTP_FROM=tu_correo@gmail.com

# ─── ENLACES DE LA APP ───
# URL del frontend para que los usuarios hagan clic en el correo
FRONTEND_URL=https://mundial-2026-zeta-sand.vercel.app

# ─── VARIABLES ADICIONALES ───
DATABASE_URL=sqlite:///./worldcup.db
SECRET_KEY=clave_secreta_para_firmar_tokens_jwt
